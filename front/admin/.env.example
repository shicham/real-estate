# API Configuration
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001
NUXT_PUBLIC_API_LOGIN_ENDPOINT=/api/auth/login
NUXT_PUBLIC_API_REGISTER_ENDPOINT=/api/auth/register

# Application
NODE_ENV=development

# Server (for local development)
HOST=localhost
PORT=3000

# Authentication
SESSION_SECRET=your_session_secret_key_min_32_characters

# i18n
DEFAULT_LOCALE=en
AVAILABLE_LOCALES=en,fr,ar

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_DARK_MODE=true
ENABLE_I18N=true
