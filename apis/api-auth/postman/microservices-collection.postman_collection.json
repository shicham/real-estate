{
  "info": {
    "name": "Microservices API Collection",
    "description": "Collection Postman pour architecture microservices. Chaque dossier correspond à une API. Les routes sont documentées avec leur objectif et variables nécessaires.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.viridial.com" },
    { "key": "auth_token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "user_email", "value": "testuser@example.com" },
    { "key": "user_password", "value": "Test1234" }
  ],
  "item": [
    {
      "name": "Auth Service",
      "description": "Gestion de l'authentification, des tokens et des profils utilisateurs.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "response": [],
          "description": "Inscription d'un nouvel utilisateur. Variables: user_email, user_password."
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.collectionVariables.set('auth_token', jsonData.data.accessToken);",
                  "  pm.collectionVariables.set('userId', jsonData.data.user._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": [],
          "description": "Connexion utilisateur. Variables: user_email, user_password. Après login, le token et l'userId sont mis à jour automatiquement."
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "user", "profile"]
            }
          },
          "response": [],
          "description": "Récupère le profil utilisateur connecté. Variable: auth_token."
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{auth_token}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh-token"]
            }
          },
          "response": [],
          "description": "Rafraîchir le token d’accès. Variable: refreshToken."
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "forgot-password"]
            }
          },
          "response": [],
          "description": "Demander la réinitialisation du mot de passe. Variable: user_email."
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset_token>\",\n  \"newPassword\": \"NewPassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password"]
            }
          },
          "response": [],
          "description": "Réinitialiser le mot de passe. Variables: token, newPassword."
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-email/{{verify_token}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "verify-email", "{{verify_token}}"]
            }
          },
          "response": [],
          "description": "Vérifier l’adresse email via le token. Variable: verify_token."
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          },
          "response": [],
          "description": "Déconnexion de l’utilisateur. Variable: auth_token."
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"OldPassword123\",\n  \"newPassword\": \"NewPassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "change-password"]
            }
          },
          "response": [],
          "description": "Changer le mot de passe. Variables: currentPassword, newPassword, auth_token."
        }
      ]
    },
    {
      "name": "User Service",
      "description": "Gestion des utilisateurs, rôles, permissions.",
      "item": [
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "user", "{{userId}}"]
            }
          },
          "response": [],
          "description": "Récupère les infos d'un utilisateur par son ID. Variables: auth_token, userId."
        }
      ]
    },
    {
      "name": "RealEstate Service",
      "description": "Gestion des biens immobiliers, annonces, favoris.",
      "item": [
        {
          "name": "List Properties",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/properties",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "properties"]
            }
          },
          "response": [],
          "description": "Liste tous les biens immobiliers. Variable: baseUrl."
        }
      ]
    }
  ]
}
