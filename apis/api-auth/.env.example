# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=3001

# MongoDB Configuration (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_USERNAME=your_username
MONGODB_PASSWORD=your_password
MONGODB_DATABASE=realestate_auth

# JWT Configuration (use strong, random 32+ character strings)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_characters
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_characters
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS Configuration (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000,http://localhost:3010,https://localhost:3010

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@realestate.com
FROM_NAME=Real Estate Platform

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=info

# Security
BCRYPT_ROUNDS=10

# Application
APP_NAME=Real Estate Platform
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Account Security
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=15

# Email Verification
EMAIL_VERIFICATION_EXPIRES=24h

# Password Reset
PASSWORD_RESET_EXPIRES=1h
